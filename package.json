{
  "name": "node-mailer",
  "version": "1.2.0",
  "description": "Service to send emails",
  "private": true,
  "main": "index.js",
  "author": {
    "name": "Giammarco Boscaro",
    "email": "giammarco.boscaro@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GiamBoscaro/mail-server.git"
  },
  "bugs": {
    "url": "https://github.com/GiamBoscaro/mail-server/issues"
  },
  "scripts": {
    "dev": "NODE_ENV=development nodemon index.js --signal SIGTERM",
    "dev:docker": "NODE_ENV=development nodemon -L index.js --signal SIGTERM",
    "start": "NODE_ENV=production node index.js",
    "start:stage": "NODE_ENV=staging node index.js",
    "jest": "jest",
    "test": "jest --testPathIgnorePatterns 'e2e/'",
    "test:ci": "jest --coverage --ci --testPathIgnorePatterns 'e2e/'",
    "test:e2e": "jest --ci -i e2e",
    "lint": "eslint *.js",
    "lint:fix": "eslint --fix .",
    "presemantic-release": "npm run lint",
    "semantic-release": "semantic-release --no-ci",
    "semantic-release:test": "semantic-release --no-ci --dry-run",
    "semantic-release:ci": "semantic-release"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "camelcase": "6.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "handlebars": "^4.7.9",
    "http-errors": "^2.0.1",
    "is-html": "2.0.0",
    "js-yaml": "^4.1.1",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "ono": "^7.1.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "axios": "1.15.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "kill-port": "^2.0.1",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "semantic-release": "^25.0.3",
    "z-schema": "4.2.4"
  },
  "config": {
    "port": "3000",
    "allow-same-version": false,
    "commit-hooks": true,
    "git-tag-version": true
  },
  "engines": {
    "node": "^22.0.0"
  },
  "eslintConfig": {
    "env": {
      "node": true
    }
  },
  "keywords": [
    "openapi",
    "api",
    "backend",
    "mailer",
    "mail",
    "node"
  ]
}
